common --enable_bzlmod

build --announce_rc
build --incompatible_strict_action_env

# Remote execution on BuildBuddy's managed Linux executors.
# API keys should stay in a user-level bazelrc or CI secret:
#   common --remote_header=x-buildbuddy-api-key=...
common:buildbuddy --remote_timeout=10m
build:buildbuddy --bes_backend=grpcs://remote.buildbuddy.io
build:buildbuddy --bes_results_url=https://app.buildbuddy.io/invocation/
build:buildbuddy --extra_toolchains=//tools/buildbuddy_llvm:cc_toolchain
build:buildbuddy --extra_execution_platforms=//tools/buildbuddy_llvm:linux_x86_64
build:buildbuddy --host_platform=//tools/buildbuddy_llvm:linux_x86_64
build:buildbuddy --jobs=50
build:buildbuddy --platforms=//tools/buildbuddy_llvm:linux_x86_64
build:buildbuddy --remote_cache_compression
build:buildbuddy --remote_download_minimal
build:buildbuddy --remote_executor=grpcs://remote.buildbuddy.io
build:buildbuddy --@rules_rust//rust/settings:extra_exec_rustc_flags=-Clink-self-contained=no
build:buildbuddy --@rules_rust//rust/settings:extra_rustc_flags=-Clink-self-contained=no
